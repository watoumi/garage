# Copy to .env and adjust as needed.

# "development" or "production". In production the app refuses to start with
# default secrets, hides /docs, and rejects wildcard CORS.
ENVIRONMENT=development

# SQLite (default, zero-config for MVP):
DATABASE_URL=sqlite:///./garage.db

# PostgreSQL (production):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/garage

# Generate a strong secret in production: `openssl rand -hex 32`
SECRET_KEY=change-this-super-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated origins allowed by CORS (frontend URL).
CORS_ORIGINS=http://localhost:3000

# Public base URL of this API, used to build absolute image URLs.
PUBLIC_BASE_URL=http://localhost:8000

# Seeded admin account (created by seed.py).
ADMIN_EMAIL=admin@garage.ma
ADMIN_PASSWORD=admin123

# When true, new garages are approved instantly (visible on the map right away).
# Set false in production to require manual admin verification.
AUTO_APPROVE_GARAGES=false
