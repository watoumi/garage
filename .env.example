# Stack-level secrets for the PRODUCTION overlay (docker-compose.prod.yml).
# Copy to .env and fill in real values:   cp .env.example .env
# .env is git-ignored — never commit real secrets.

# --- Database ---
POSTGRES_PASSWORD=change-me-strong-db-password

# --- Backend / Auth ---
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-with-openssl-rand-hex-32
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-strong-admin-password

# Comma-separated list of allowed origins (no wildcard in production).
CORS_ORIGINS=https://yourdomain.com
# Public URL used to build absolute image links.
PUBLIC_BASE_URL=https://yourdomain.com/api

# --- Monitoring ---
GRAFANA_PASSWORD=change-me-grafana-password
